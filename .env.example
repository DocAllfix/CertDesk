# ─────────────────────────────────────────────────────────────
# CertDesk — Variabili di ambiente
# Copia in .env.local (sviluppo) o .env.production (deploy)
# MAI committare file con valori reali
# ─────────────────────────────────────────────────────────────

# ── Identità cliente ──────────────────────────────────────────
VITE_APP_NAME="CertDesk"
VITE_CLIENTE_NAME="Ragione Sociale Srl"

# Logo e favicon: file in public/ (es. /logo-cliente.svg)
VITE_LOGO_URL="/logo-default.svg"
VITE_FAVICON_URL="/favicon.svg"

# ── Tema colori (hex) ─────────────────────────────────────────
# NOTA: queste variabili sono lette da APP_CONFIG ma NON sovrascrivono
# automaticamente il design system CSS (che usa valori HSL hardcoded in
# index.css). Per personalizzare i colori per un cliente, modificare
# direttamente le variabili --primary / --secondary in index.css prima
# del build. Implementazione runtime hex→HSL pianificata come feature futura.
VITE_PRIMARY_COLOR="#3b82f6"
VITE_ACCENT_COLOR="#8b5cf6"

# ── Funzionalità ──────────────────────────────────────────────
# Lasciare vuoto per abilitare tutte le 17 norme.
# Per limitare: JSON array con i codici norme desiderati.
# Esempio: VITE_NORME_ABILITATE=["ISO 9001","ISO 14001","ISO 45001"]
VITE_NORME_ABILITATE=

# ── Supabase ──────────────────────────────────────────────────
# Recupera da: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL="https://xxx.supabase.co"
VITE_SUPABASE_ANON_KEY="eyJ..."
# ⚠️ MAI inserire service_role key nel frontend
